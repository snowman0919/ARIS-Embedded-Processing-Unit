# Copy to .env and edit locally. Do not commit .env.

# NVIDIA NGC PyTorch image for DGX Spark / aarch64.
# Pick a current arm64-compatible tag from NVIDIA NGC for your installed driver/CUDA stack.
NGC_PYTORCH_IMAGE=nvcr.io/nvidia/pytorch:<choose-current-arm64-dgx-spark-compatible-tag>

# Repository-local defaults are set by flake.nix and scripts.
# Optional override, if you keep data elsewhere. Use an absolute path.
# ARIS_HOME=/home/your-user/aris
ARIS_DOMAIN_ID=42
ROS_DOMAIN_ID=42
ROS_LOCALHOST_ONLY=1
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Safety default: real actuator output is disabled.
ARIS_ENABLE_REAL_ACTUATION=0

# GUI forwarding, if using RViz/Gazebo.
DISPLAY=${DISPLAY}
# Optional: override if your desktop uses a nonstandard readable Xauthority path.
# ARIS_XAUTHORITY=/home/your-user/.Xauthority
# Last-resort debugging only, when X access is granted by xhost or another mechanism.
ARIS_SKIP_X11_CHECK=0
